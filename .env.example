# ─── OpenAI ───────────────────────────────────────────────────
# Get from: platform.openai.com → API Keys
# Requires GPT-4o access on your account
OPENAI_API_KEY=sk-your-openai-api-key-here

# ─── Supabase ─────────────────────────────────────────────────
# Get from: supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co

# Public anon key — safe for client-side (but not used here)
SUPABASE_ANON_KEY=eyJ-your-anon-key-here

# Service role key — server-side only, never expose to client
SUPABASE_SERVICE_ROLE_KEY=eyJ-your-service-role-key-here

# ─── WhatsApp Business Cloud API ──────────────────────────────
# Get from: developers.facebook.com → your app → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# Get from: developers.facebook.com → your app → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=EAA-your-access-token-here

# Create this yourself — any string, used to verify webhook URL
# Must match exactly what you enter in Meta webhook configuration
WHATSAPP_VERIFY_TOKEN=suvidha_verify_2026

# Get from: developers.facebook.com → your app → Settings → Basic → App Secret
WHATSAPP_APP_SECRET=your-app-secret-here

# ─── Application ──────────────────────────────────────────────
# Port the backend server listens on (Railway sets this automatically)
PORT=3001

# URL of the deployed frontend — used for CORS
# Development: http://localhost:3000
# Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000

# Set to 'production' on Railway, 'development' locally
NODE_ENV=development

# API authentication key — required in production. Clients must send this as x-api-key header.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET_KEY=your-api-secret-key-here

# How long generated files are kept before deletion (hours)
FILE_TTL_HOURS=24
